{
  "name": "@smartgrid/backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "check": "bunx biome check . && tsc --noEmit",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/eden": "latest",
    "@elysiajs/jwt": "latest",
    "@elysiajs/swagger": "^1.3.1",
    "@node-rs/argon2": "^2.0.2",
    "@smartgrid/shared": "*",
    "drizzle-orm": "^0.45.2",
    "elysia": "latest",
    "node-cron": "latest"
  },
  "devDependencies": {
    "@smartgrid/config": "*",
    "@types/node-cron": "latest",
    "bun-types": "^1.3.13",
    "typescript": "5.9.2"
  }
}
